{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn -w 2 --timeout 120 -k uvicorn.workers.UvicornWorker phase4_api.main:app --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "numReplicas": 1
  }
}
